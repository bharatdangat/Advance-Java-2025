class DemoAZ extends Thread
{
	@Override
	public void run() {
	for(char i='A';i<='Z';i++)
	{
		try
		{
		System.out.println(i);
		sleep(2000);
		}catch(InterruptedException e)
		{
			System.out.println(e);
		}
	}
	}
}
public class AtoZ 
{
	public static void main(String[] args)
	{
     DemoAZ ob=new DemoAZ();
     ob.start();
	}

}
